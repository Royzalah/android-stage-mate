<!-- 
Skeleton Fade In Animation
Used when content loads over skeleton
Duration: 300ms (Medium 2)
-->
<alpha xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="@integer/motion_duration_medium_2"
