<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/category_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/margin_small"
    app:cardCornerRadius="@dimen/corner_radius_pill"
    app:cardElevation="@dimen/elevation_card"
    app:cardBackgroundColor="@color/background_card"
    app:strokeColor="@color/stroke_faint"
    app:strokeWidth="@dimen/stroke_thin">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/padding_medium"
        android:paddingTop="@dimen/padding_small"
        android:paddingEnd="@dimen/padding_medium"
        android:paddingBottom="@dimen/padding_small">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/category_IMG_icon"
            android:layout_width="@dimen/icon_medium"
            android:layout_height="@dimen/icon_medium"
            android:layout_marginEnd="@dimen/margin_xs"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.StageMate.Circle"
            tools:src="@drawable/category_music" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/category_LBL_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            style="@style/TextAppearance.StageMate.BodyMedium"
            tools:text="Music" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
