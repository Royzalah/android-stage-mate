<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:padding="@dimen/padding_medium">

    <!-- Title -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/security_LBL_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/security_title"
        android:textColor="@color/text_primary"
        android:textAppearance="@style/TextAppearance.StageMate.TitleLarge"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Current Password -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/security_TIL_current_password"
        style="@style/Widget.StageMate.TextInputLayout.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_large"
        android:hint="@string/current_password"
        app:endIconMode="password_toggle"
        app:layout_constraintTop_toBottomOf="@id/security_LBL_title">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/security_EDT_current_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/text_primary" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- New Password -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/security_TIL_new_password"
        style="@style/Widget.StageMate.TextInputLayout.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_medium"
        android:hint="@string/new_password"
        app:endIconMode="password_toggle"
        app:layout_constraintTop_toBottomOf="@id/security_TIL_current_password">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/security_EDT_new_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/text_primary" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Confirm Password -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/security_TIL_confirm_password"
        style="@style/Widget.StageMate.TextInputLayout.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_medium"
        android:hint="@string/confirm_new_password"
        app:endIconMode="password_toggle"
        app:layout_constraintTop_toBottomOf="@id/security_TIL_new_password">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/security_EDT_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/text_primary" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Change Password Button - Pill Gradient -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/security_BTN_change_password"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_large"
        android:layout_marginTop="@dimen/margin_large"
        android:text="@string/change_password"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:background="@drawable/bg_gradient_button"
        app:backgroundTint="@null"
        app:cornerRadius="@dimen/corner_radius_pill"
        app:elevation="@dimen/elevation_card"
        app:layout_constraintTop_toBottomOf="@id/security_TIL_confirm_password" />


</androidx.constraintlayout.widget.ConstraintLayout>
