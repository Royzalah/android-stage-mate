<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_category_card"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_margin="@dimen/margin_small"
    app:cardCornerRadius="@dimen/corner_radius_card"
    app:cardElevation="@dimen/elevation_card"
    app:strokeWidth="2dp"
    app:strokeColor="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Category Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/item_category_IMG"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Overlay -->
        <View
            android:id="@+id/item_category_overlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/card_background_dark"
            android:alpha="0.3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Category Name -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/item_category_LBL_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_music_label"
            android:textColor="@color/text_primary"
            android:textAppearance="@style/TextAppearance.StageMate.HeadlineMedium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Selected Indicator (Checkmark) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/item_category_IMG_selected"
            android:layout_width="@dimen/icon_large"
            android:layout_height="@dimen/icon_large"
            android:src="@drawable/ic_check"
            android:visibility="gone"
            android:background="@drawable/circle_background"
            android:backgroundTint="@color/primary"
            android:padding="@dimen/spacing_small"
            app:tint="@color/text_on_primary"
            android:layout_margin="@dimen/margin_small"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
