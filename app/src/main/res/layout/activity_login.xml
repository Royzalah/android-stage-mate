<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/gradient_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="28dp"
        android:paddingTop="@dimen/icon_xl"
        android:paddingBottom="@dimen/padding_xl">

        <!-- ═══ Welcome Header ═══ -->

        <!-- Welcome Title -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/login_LBL_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_back"
            android:textColor="@color/text_primary"
            android:textAppearance="@style/TextAppearance.StageMate.HeadlineMedium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Subtitle -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/login_LBL_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_xs"
            android:text="@string/login_subtitle"
            android:textColor="@color/text_secondary"
            style="@style/TextAppearance.StageMate.BodyMedium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/login_LBL_title" />

        <!-- ═══ Form Glass Card ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/login_CV_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_xl"
            app:cardCornerRadius="@dimen/corner_radius_xl"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_input_bg"
            app:strokeColor="@color/stroke_subtle"
            app:strokeWidth="@dimen/stroke_thin"
            app:layout_constraintTop_toBottomOf="@id/login_LBL_subtitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xxl">

                <!-- Email Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/login_TIL_username"
                    style="@style/Widget.StageMate.TextInputLayout.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/email"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/accent_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/login_EDT_username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/login_TIL_password"
                    style="@style/Widget.StageMate.TextInputLayout.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:hint="@string/password"
                    app:endIconMode="password_toggle"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/accent_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/login_EDT_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Remember Me -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/login_CHK_remember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:text="@string/remember_me"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/poppins"
                    android:textSize="@dimen/text_size_body_small"
                    android:buttonTint="@color/accent_primary" />

                <!-- Forgot Password Link -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/login_LBL_forgot_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="@dimen/margin_xs"
                    android:text="@string/forgot_password"
                    android:textColor="@color/accent_secondary"
                    android:fontFamily="@font/poppins"
                    android:textSize="@dimen/text_size_body_small" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ Login Button — Gradient Pill ═══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/login_BTN_login"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/login"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_regular"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:fontFamily="@font/poppins_semibold"
            app:backgroundTint="@color/accent_primary"
            app:cornerRadius="@dimen/corner_radius_pill"
            app:rippleColor="@color/ripple_on_dark"
            app:elevation="@dimen/elevation_large"
            app:layout_constraintTop_toBottomOf="@id/login_CV_form" />

        <!-- ═══ Divider with "Or" ═══ -->
        <View
            android:id="@+id/login_VIEW_divider_left"
            android:layout_width="0dp"
            android:layout_height="@dimen/stroke_thin"
            android:layout_marginTop="@dimen/category_icon_size"
            android:layout_marginEnd="@dimen/margin_medium"
            android:background="@color/divider"
            app:layout_constraintEnd_toStartOf="@id/login_LBL_or"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/login_BTN_login" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/login_LBL_or"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/or"
            android:textColor="@color/text_hint"
            android:fontFamily="@font/poppins"
            android:textSize="@dimen/text_size_body_small"
            app:layout_constraintBottom_toBottomOf="@id/login_VIEW_divider_left"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/login_VIEW_divider_left" />

        <View
            android:id="@+id/login_VIEW_divider_right"
            android:layout_width="0dp"
            android:layout_height="@dimen/stroke_thin"
            android:layout_marginStart="@dimen/margin_medium"
            android:background="@color/divider"
            app:layout_constraintBottom_toBottomOf="@id/login_VIEW_divider_left"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/login_LBL_or"
            app:layout_constraintTop_toTopOf="@id/login_VIEW_divider_left" />

        <!-- ═══ Google Sign-In — Glass Pill Button ═══ -->
        <LinearLayout
            android:id="@+id/login_LL_social"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/login_VIEW_divider_left">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/login_BTN_google"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/icon_xl"
                android:text="@string/sign_in_with_google"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_medium"
                android:fontFamily="@font/poppins"
                android:textAllCaps="false"
                app:icon="@drawable/ic_google"
                app:iconGravity="start"
                app:iconPadding="@dimen/spacing_large"
                app:iconSize="@dimen/spacing_xxl"
                app:iconTint="@null"
                app:cornerRadius="@dimen/corner_radius_pill"
                app:strokeColor="@color/input_stroke"
                app:strokeWidth="@dimen/stroke_thin"
                app:backgroundTint="@color/input_bg_subtle"
                app:elevation="0dp" />

        </LinearLayout>

        <!-- ═══ Sign Up Link ═══ -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/login_LBL_signup_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_xl"
            android:text="@string/dont_have_account"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/poppins"
            android:textSize="@dimen/text_size_medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/login_LL_social" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
