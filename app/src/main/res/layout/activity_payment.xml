<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- ═══════════════════════════════════════════ -->
    <!-- FIXED TOP: Toolbar                          -->
    <!-- ═══════════════════════════════════════════ -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/payment_TOOLBAR_main"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_top_bar_glass"
        android:elevation="0dp"
        app:title="@string/payment_title"
        app:titleTextColor="@color/text_on_primary"
        app:titleTextAppearance="@style/TextAppearance.StageMate.TitleMedium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════════════════════════════════════ -->
    <!-- PAYMENT TIMER — 7-minute countdown          -->
    <!-- ═══════════════════════════════════════════ -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/payment_LBL_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/margin_medium"
        android:text="@string/payment_timer_initial"
        android:textColor="@color/accent_secondary"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="@dimen/text_size_body"
        android:visibility="visible"
        app:drawableStartCompat="@drawable/ic_time"
        android:drawablePadding="@dimen/padding_small"
        app:drawableTint="@color/accent_secondary"
        app:layout_constraintTop_toTopOf="@id/payment_TOOLBAR_main"
        app:layout_constraintBottom_toBottomOf="@id/payment_TOOLBAR_main"
        app:layout_constraintEnd_toEndOf="@id/payment_TOOLBAR_main" />

    <!-- ═══════════════════════════════════════════ -->
    <!-- PROGRESS INDICATOR — step 1 of 2           -->
    <!-- Controlled from Activity: setProgress(50)  -->
    <!-- ═══════════════════════════════════════════ -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/payment_PB_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:progress="50"
        android:max="100"
        app:indicatorColor="@color/primary"
        app:trackColor="@color/neutral_n200"
        app:trackThickness="@dimen/elevation_medium"
        app:layout_constraintTop_toBottomOf="@id/payment_TOOLBAR_main"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════════════════════════════════════ -->
    <!-- FRAGMENT CONTAINER                          -->
    <!-- NavHostFragment goes here                   -->
    <!-- ═══════════════════════════════════════════ -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/payment_LAYOUT_fragment_container"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/payment_PB_progress"
        app:layout_constraintVertical_bias="0.0" />

</androidx.constraintlayout.widget.ConstraintLayout>