<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-bleed Image -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/onboarding_IMG_illustration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/cd_onboarding_illustration"
        android:scaleType="centerCrop" />

    <!-- Dark gradient overlay for readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_semi" />

    <!-- Bottom gradient fade to dark -->
    <View
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom_fade" />

    <!-- Floating Dark Glass Card -->
    <LinearLayout
        android:id="@+id/onboarding_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_card_top_rounded_glass"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/padding_xl"
        android:paddingTop="@dimen/image_medium"
        android:paddingBottom="@dimen/event_image_height_compact"
        android:elevation="@dimen/elevation_large">

        <!-- Title -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/onboarding_LBL_title"
            style="@style/TextAppearance.StageMate.HeadlineSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/outfit_semibold"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_title"
            android:letterSpacing="0.02" />

        <!-- Description -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/onboarding_LBL_description"
            style="@style/TextAppearance.StageMate.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_body_large" />

    </LinearLayout>

</FrameLayout>
