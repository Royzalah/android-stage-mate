<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
    Material Design 3 Type Scale
    Based on: https://m3.material.io/styles/typography/overview
    
    Type Scale Roles:
    - Display: Large, expressive headlines
    - Headline: High-emphasis headlines
    - Title: Medium-emphasis text
    - Body: Main readable text
    - Label: Small, utilitarian text
    -->
    
    <!-- ========== DISPLAY ========== -->
    <style name="TextAppearance.StageMate.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">45sp</item>
        <item name="lineHeight">52sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.StageMate.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">36sp</item>
        <item name="lineHeight">44sp</item>
        <item name="android:letterSpacing">0</item>
    </style>
    
    <!-- ========== HEADLINE ========== -->
    <!-- High-emphasis text, shorter than display -->
    
    <style name="TextAppearance.StageMate.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">32sp</item>
        <item name="lineHeight">40sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.StageMate.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">28sp</item>
        <item name="lineHeight">36sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.StageMate.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">@font/outfit_semibold</item>
        <item name="fontFamily">@font/outfit_semibold</item>
        <item name="android:textSize">24sp</item>
        <item name="lineHeight">32sp</item>
        <item name="android:letterSpacing">0</item>
    </style>
    
    <!-- ========== TITLE ========== -->
    <!-- Medium-emphasis text for sections -->
    
    <style name="TextAppearance.StageMate.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">22sp</item>
        <item name="lineHeight">28sp</item>
        <item name="android:letterSpacing">0</item>
    </style>
    
    <style name="TextAppearance.StageMate.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
        <item name="android:letterSpacing">0.0015</item>
    </style>    
    <!-- ========== BODY ========== -->
    <!-- Main readable content -->
    
    <style name="TextAppearance.StageMate.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>
    
    <style name="TextAppearance.StageMate.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">20sp</item>
        <item name="android:letterSpacing">0.0025</item>
    </style>
    
    <style name="TextAppearance.StageMate.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">12sp</item>
        <item name="lineHeight">16sp</item>
        <item name="android:letterSpacing">0.004</item>
    </style>
    
    <!-- ========== LABEL ========== -->
    <!-- Small, utilitarian text (buttons, tabs) -->
    
    <style name="TextAppearance.StageMate.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">20sp</item>
        <item name="android:letterSpacing">0.001</item>
    </style>
    
    <style name="TextAppearance.StageMate.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="lineHeight">16sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>
    
    <style name="TextAppearance.StageMate.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">11sp</item>
        <item name="lineHeight">16sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>
    
    <!-- ========== COMMON USE CASES ========== -->    
    <!-- Button Text -->
    <style name="TextAppearance.StageMate.Button" parent="TextAppearance.StageMate.LabelLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
    </style></resources>
