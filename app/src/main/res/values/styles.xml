<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Shape Appearance Overlay -->
    <style name="ShapeAppearanceOverlay.Rounded16" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.Rounded28" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.Rounded8" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearanceOverlay.Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <!-- Rounded Corner Image -->
    <style name="RoundedCorner">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="RoundedCornerImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <!-- ═══════════════════════════════════════════════ -->
    <!-- StageMate M3 TextInputLayout Styles             -->
    <!-- ═══════════════════════════════════════════════ -->

    <!-- Filled — dark card background, fully rounded corners -->
    <style name="Widget.StageMate.TextInputLayout.Filled" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/background_card</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxStrokeColor">@color/accent_primary</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <!-- Outlined — surface background, purple stroke -->
    <style name="Widget.StageMate.TextInputLayout.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/accent_primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/accent_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Material Base Styles (for compatibility) -->
    <style name="Widget.Material3.Button" parent="Widget.MaterialComponents.Button" />
    <style name="Widget.Material3.CircularProgressIndicator" parent="Widget.MaterialComponents.CircularProgressIndicator" />
    <style name="Widget.Material3.Button.OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton" />
    
    <!-- Shape Appearance -->
    <style name="ShapeAppearance.Material3.Corner.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <style name="ShapeAppearance.Material3.Corner.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Material3.Corner.Small" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.Material3.Corner.Full" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>    
    <!-- Material3 Widget Styles (Additional) -->
    <style name="Widget.Material3.Button.Icon" parent="Widget.Material3.Button">
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
    </style>

    <style name="Widget.Material3.Button.IconButton" parent="Widget.Material3.Button">
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Material3.Button.TextButton"
        parent="Widget.MaterialComponents.Button.TextButton" />

    <!-- StageMate Filter Chip — no checkmark, purple glow on selection -->
    <style name="Widget.StageMate.Chip.Filter" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="checkedIconVisible">false</item>
        <item name="chipIconVisible">false</item>
    </style>

    <!-- Circle — for floating splash images -->
    <style name="ShapeAppearance.StageMate.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Onboarding Card — only top corners rounded -->
    <style name="ShapeAppearance.StageMate.CardTopRounded" parent="">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Event card image — top corners match card radius -->
    <style name="ShapeAppearance.StageMate.EventImage" parent="">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>
