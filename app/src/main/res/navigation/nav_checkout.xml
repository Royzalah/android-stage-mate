<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_checkout"
    app:startDestination="@id/orderSummaryFragment">

    <fragment
        android:id="@+id/orderSummaryFragment"
        android:name="com.roei.stagemate.ui.fragments.OrderSummaryFragment"
        android:label="@string/order_summary_title"
        tools:layout="@layout/fragment_order_summary">
        <action
            android:id="@+id/action_orderSummaryFragment_to_paymentDetailsFragment"
            app:destination="@id/paymentDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/paymentDetailsFragment"
        android:name="com.roei.stagemate.ui.fragments.PaymentDetailsFragment"
        android:label="@string/payment_details"
        tools:layout="@layout/fragment_payment_details" />

</navigation>
